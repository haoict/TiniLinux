BR2_TARGET_GENERIC_HOSTNAME="tinilinux"
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_TiniLinux_PATH)/board/qemu_aarch64/linux/linux.conf"
BR2_LINUX_KERNEL_DTS_SUPPORT=n
BR2_LINUX_KERNEL_NEEDS_HOST_LIBELF=y
BR2_PACKAGE_BLUEZ_TOOLS=n
BR2_PACKAGE_BLUEZ5_UTILS=n
BR2_PACKAGE_WPA_SUPPLICANT=n
BR2_PACKAGE_GPTOKEYB2=n
BR2_PACKAGE_ROCKNIX_JOYPAD=n
BR2_TARGET_GRUB2=y
BR2_TARGET_GRUB2_BUILTIN_MODULES_EFI="boot linux ext2 fat squash4 part_msdos part_gpt normal efi_gop configfile search search_fs_file gzio"
