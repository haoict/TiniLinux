/dts-v1/;
/plugin/;

/ {
    compatible = "brcm,bcm2835";

    fragment@0 {
        target = <&spi0>;
        __overlay__ {
            #address-cells = <1>;
            #size-cells = <0>;
            status = "okay";

            display@0 {
                compatible = "panel-mipi-dbi-spi";
                reg = <0>;
                spi-max-frequency = <96000000>; /* drop to 64MHz if pixel corruption */
                spi-tx-bus-width = <1>;
                dc-gpios = <&gpio 25 0>;
                reset-gpios = <&gpio 27 0>;
                backlight = <&backlight>;
                width-mm = <24>;
                height-mm = <24>;

                panel-timing {
                    hactive = <240>;
                    vactive = <240>;
                    hback-porch = <0>;
                    vback-porch = <0>;
                    hfront-porch = <0>;
                    vfront-porch = <0>;
                    hsync-len = <0>;
                    vsync-len = <0>;
                    clock-frequency = <0>;
                };
            };
        };
    };

    /* declare pull-ups via pinctrl - applied by kernel, survives firmware resets */
    fragment@1 {
        target = <&gpio>;
        __overlay__ {
            button_pins: button_pins {
                brcm,pins = <6 19 5 26 13 21 20 16>;
                brcm,function = <0>;  /* INPUT */
                brcm,pull = <2>;      /* PULL_UP */
            };

            /* set GPIO24 to ALT5 = PWM0 is NOT available on GPIO24.
               GPIO24 has no hardware PWM alt function, so we use
               pwm-gpio (software PWM) instead — no pinctrl needed */
        };
    };

    fragment@2 {
        target-path = "/";
        __overlay__ {
            /* Control brightness. Check max_brightness: cat /sys/class/backlight/backlight/max_brightness */
            /* echo 4 > /sys/class/backlight/backlight/brightness   # ~25% */
            /* echo 8 > /sys/class/backlight/backlight/brightness   # 100% */
            /* echo 0 > /sys/class/backlight/backlight/brightness   # off  */
            /* Consoleblanking also turn off the lcd: echo 1 > /sys/class/graphics/fb1/blank  */

            /* Software PWM on GPIO 24 */
            pwm_bl: pwm-gpio {
                compatible = "pwm-gpio";
                #pwm-cells = <3>;
                gpios = <&gpio 24 0>;
            };

            backlight: backlight {
                compatible = "pwm-backlight";
                pwms = <&pwm_bl 0 50000 0>; /* channel 0, 50µs period = 20kHz, normal polarity */
                brightness-levels = <0 4 8 16 32 64 128 192 255>;
                default-brightness-level = <8>; /* index 8 = 255 = full */
            };

            gpio-keys {
                compatible = "gpio-keys";
                autorepeat;
                pinctrl-names = "default";
                pinctrl-0 = <&button_pins>;

                /* file:///usr/include/linux/input-event-codes.h */
                up {
                    label = "joystick up";
                    linux,code = <103>;   /* KEY_UP */
                    gpios = <&gpio 6 1>;  /* active low */
                    debounce-interval = <20>;
                };
                down {
                    label = "joystick down";
                    linux,code = <108>;   /* KEY_DOWN */
                    gpios = <&gpio 19 1>;
                    debounce-interval = <20>;
                };
                left {
                    label = "joystick left";
                    linux,code = <105>;   /* KEY_LEFT */
                    gpios = <&gpio 5 1>;
                    debounce-interval = <20>;
                };
                right {
                    label = "joystick right";
                    linux,code = <106>;   /* KEY_RIGHT */
                    gpios = <&gpio 26 1>;
                    debounce-interval = <20>;
                };
                press {
                    label = "joystick press";
                    linux,code = <28>;    /* KEY_ENTER */
                    gpios = <&gpio 13 1>;
                    debounce-interval = <20>;
                };
                a {
                    label = "button a";
                    linux,code = <1>;     /* KEY_ESC */
                    gpios = <&gpio 21 1>;
                    debounce-interval = <20>;
                };
                b {
                    label = "button b";
                    linux,code = <44>;    /* KEY_Z */
                    gpios = <&gpio 20 1>;
                    debounce-interval = <20>;
                };
                x {
                    label = "button x";
                    linux,code = <45>;    /* KEY_X */
                    gpios = <&gpio 16 1>;
                    debounce-interval = <20>;
                };
            };
        };
    };
};