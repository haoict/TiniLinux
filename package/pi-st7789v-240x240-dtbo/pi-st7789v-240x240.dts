/dts-v1/;
/plugin/;

/ {
    compatible = "brcm,bcm2835";

    fragment@0 {
        target = <&spi0>;
        __overlay__ {
            #address-cells = <1>;
            #size-cells = <0>;
            status = "okay";

            display@0 {
                compatible = "panel-mipi-dbi-spi";
                reg = <0>;
                spi-max-frequency = <64000000>;
                dc-gpios = <&gpio 25 0>;
                reset-gpios = <&gpio 27 0>;
                rotation = <0>;
                width-mm = <24>;
                height-mm = <24>;

                panel-timing {
                    hactive = <240>;
                    vactive = <240>;
                    hback-porch = <0>;
                    vback-porch = <0>;
                    hfront-porch = <0>;
                    vfront-porch = <0>;
                    hsync-len = <0>;
                    vsync-len = <0>;
                    clock-frequency = <0>;
                };
            };
        };
    };

    fragment@1 {
        target-path = "/";
        __overlay__ {
            gpio-keys {
                compatible = "gpio-keys";
                autorepeat;

                /* file:///usr/include/linux/input-event-codes.h */
                up {
                    label = "joystick up";
                    linux,code = <103>;    /* KEY_UP */
                    gpios = <&gpio 6 1>;   /* active low */
                };
                down {
                    label = "joystick down";
                    linux,code = <108>;    /* KEY_DOWN */
                    gpios = <&gpio 19 1>;
                };
                left {
                    label = "joystick left";
                    linux,code = <105>;    /* KEY_LEFT */
                    gpios = <&gpio 5 1>;
                };
                right {
                    label = "joystick right";
                    linux,code = <106>;    /* KEY_RIGHT */
                    gpios = <&gpio 26 1>;
                };
                press {
                    label = "joystick press";
                    linux,code = <28>;     /* KEY_ENTER */
                    gpios = <&gpio 13 1>;
                };
                a {
                    label = "button a";
                    linux,code = <1>;     /* KEY_ESC */
                    gpios = <&gpio 21 1>;
                };
                b {
                    label = "button b";
                    linux,code = <44>;     /* KEY_Z */
                    gpios = <&gpio 20 1>;
                };
                x {
                    label = "button x";
                    linux,code = <45>;     /* KEY_X */
                    gpios = <&gpio 16 1>;
                };
            };
        };
    };
};